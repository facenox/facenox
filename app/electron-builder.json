{
  "files": ["out/**/*"],
  "appId": "com.atracana.app",
  "productName": "Atracana AI Attendance Tracker",
  "icon": "./public/icons/atracana_mark_logo_round_c.png",
  "beforePack": "scripts/before-pack.mjs",
  "win": {
    "target": "nsis",
    "artifactName": "Atracana-Setup-v${version}.${ext}",
    "extraResources": [
      {
        "from": "../server/dist/server.exe",
        "to": "server/server.exe"
      },
      {
        "from": "public/icons",
        "to": "icons"
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "perMachine": false,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "deleteAppDataOnUninstall": false,
    "runAfterFinish": true,
    "artifactName": "Atracana-Setup-v${version}.${ext}"
  },
  "linux": {
    "target": "AppImage",
    "category": "utility",
    "extraResources": [
      {
        "from": "../server/dist/server",
        "to": "server/server"
      }
    ]
  },
  "mac": {
    "target": "dmg",
    "extraResources": [
      {
        "from": "../server/dist/server",
        "to": "server/server"
      }
    ]
  }
}
